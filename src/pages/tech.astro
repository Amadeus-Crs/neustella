---
/**
 * 技术分类页
 * 展示所有技术类文章
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles', (entry) =>
  entry.data.category === 'tech' && !entry.data.draft
);
articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="技术 — Neustella" description="技术相关文章">
  <div class="max-w-2xl mx-auto px-6 py-12">
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-2">
        <span class="w-2 h-2 rounded-full bg-[#7de3f5]"></span>
        <h1 class="text-3xl font-light text-[#f5f5f0] tracking-wide">技术</h1>
      </div>
      <p class="text-sm text-[#a0a098]">代码、工具与工程的思考</p>
    </header>

    <div class="space-y-4">
      {articles.length === 0 && (
        <p class="text-sm text-[#a0a098] text-center py-12">暂无技术类文章</p>
      )}
      {articles.map((article) => (
        <ArticleCard
          title={article.data.title}
          date={article.data.date}
          description={article.data.description}
          slug={article.id}
          category={article.data.category}
        />
      ))}
    </div>
  </div>
</BaseLayout>
