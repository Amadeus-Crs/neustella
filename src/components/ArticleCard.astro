---
/**
 * ArticleCard.astro
 * 文章列表中的卡片组件
 */

interface Props {
  title: string;
  date: Date;
  description: string;
  slug: string;
  category: 'tech' | 'observe';
}

const { title, date, description, slug, category } = Astro.props;

const categoryLabel = category === 'tech' ? '技术' : '观察';
const categoryColor = category === 'tech' ? 'text-[#7de3f5]' : 'text-[#c8a87c]';
const categoryBorder = category === 'tech' ? 'border-[#7de3f5]/20' : 'border-[#c8a87c]/20';
const categoryBg = category === 'tech' ? 'hover:bg-[#7de3f5]/5' : 'hover:bg-[#c8a87c]/5';
---

<a
  href={`/neustella/articles/${slug}`}
  class={`block p-6 rounded-lg border ${categoryBorder} ${categoryBg} transition-all duration-300 group`}
>
  <div class="flex items-center gap-3 mb-3">
    <span class={`text-xs tracking-wider ${categoryColor}`}>
      {categoryLabel}
    </span>
    <time class="text-xs text-[#a0a098]" datetime={date.toISOString()}>
      {date.toLocaleDateString('zh-CN', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      })}
    </time>
  </div>
  <h2 class="text-xl font-light text-[#f5f5f0] group-hover:text-[#d4c4a8] transition-colors duration-300 mb-2">
    {title}
  </h2>
  <p class="text-sm text-[#a0a098] leading-relaxed line-clamp-2">
    {description}
  </p>
</a>
