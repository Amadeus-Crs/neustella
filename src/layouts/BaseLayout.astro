---
/**
 * BaseLayout.astro
 * 全站基础布局，禅意深空风格
 */

import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Neustella', description = '一个关于技术与观察的个人博客' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- 预加载中文字体 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500&family=Noto+Serif+SC:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col bg-[#0a0a0f] text-[#f5f5f0]">
    <!-- 顶部导航 -->
    <nav class="w-full border-b border-[#2a2a35]/50 backdrop-blur-sm sticky top-0 z-50 bg-[#0a0a0f]/80">
      <div class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/neustella/" class="text-lg font-light tracking-widest text-[#f5f5f0] hover:text-[#c8a87c] transition-colors duration-300">
          NEUSTELLA
        </a>
        <div class="flex gap-6 text-sm">
          <a href="/neustella/" class="text-[#a0a098] hover:text-[#f5f5f0] transition-colors duration-300">
            星图
          </a>
          <a href="/neustella/articles" class="text-[#a0a098] hover:text-[#f5f5f0] transition-colors duration-300">
            文章
          </a>
        </div>
      </div>
    </nav>

    <!-- 主内容 -->
    <main class="flex-1 w-full">
      <slot />
    </main>

    <!-- 底部 -->
    <footer class="w-full border-t border-[#2a2a35]/30 py-8 mt-12">
      <div class="max-w-3xl mx-auto px-6 text-center text-xs text-[#a0a098]/60">
        <p>Neustella — 在星辰与代码之间</p>
        <p class="mt-1">Built with Astro &amp; stardust</p>
      </div>
    </footer>
  </body>
</html>
